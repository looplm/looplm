# Database
DATABASE_URL=postgresql+asyncpg://looplm:looplm@localhost:5432/looplm
POSTGRES_USER=looplm
POSTGRES_PASSWORD=looplm
POSTGRES_DB=looplm

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
DEBUG=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3100

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_REPOSITORY_URL=

# LLM (for analysis engine)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANALYSIS_LLM_PROVIDER=openai
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=

# Evaluations
EVAL_TARGET_ENDPOINT=
EVAL_DEFAULT_CONCURRENCY=2

# Auto-grading
AUTO_GRADE_ENABLED=false
AUTO_GRADE_INTERVAL_MINUTES=5
AUTO_GRADE_BATCH_SIZE=20
AUTO_GRADE_MIN_OUTPUT_LENGTH=50

# Update check — looks up the latest GitHub release for the About settings panel.
# Set to false for air-gapped deployments. GITHUB_TOKEN is optional and only
# raises GitHub's anonymous rate limit (60/h per IP).
UPDATE_CHECK_ENABLED=true
GITHUB_TOKEN=

# Platform admin — the email below is treated as platform admin even if the
# users row hasn't been promoted yet. The first registered user is also
# auto-promoted; this var is mainly for recovery and pre-existing deploys.
INSTANCE_OWNER_EMAIL=

# GitHub App — enables the Code Agent to clone connected repos via browser auth.
# Leave GITHUB_APP_ID empty to disable the feature entirely.
# Register an App at github.com/settings/apps. Required permissions:
#   Repository → Contents: Read, Metadata: Read.
# The callback URL on the App settings page must be:
#   <your-frontend-origin>/github/callback
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Pass the PEM contents (escape newlines as \n) OR set GITHUB_APP_PRIVATE_KEY_PATH.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_CLONE_DIR=/var/looplm/repos

# Connectors
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGSMITH_API_KEY=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=

# MinIO / Object Storage
MINIO_ROOT_USER=looplm
MINIO_ROOT_PASSWORD=looplm123
MINIO_ENDPOINT=http://localhost:9000
